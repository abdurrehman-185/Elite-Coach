# Tavily API Key for law firm intelligence
TAVILY_API_KEY=

# Groq API Key for AI Analysis
GROQ_API_KEY=

# Optional comma-separated fallback keys. The backend rotates to the next key
# automatically on rate-limit/quota errors. Keep this server-side only.
GROQ_API_KEYS=

# Optional Groq model override
GROQ_MODEL=llama-3.3-70b-versatile

# Optional AI protection controls
AI_RATE_LIMIT_PER_MINUTE=5
AI_RATE_LIMIT_PER_DAY=50
AI_CACHE_SIMILARITY_THRESHOLD=0.92
